RUN_ID=gtx1660_local
DATA_PATH=./data/datasets/fineweb10B_sp1024
TOKENIZER_PATH=./data/tokenizers/fineweb_1024_bpe.model
VOCAB_SIZE=1024

COMPUTE_DTYPE=float16
MUON_DTYPE=float32
ENABLE_COMPILE=0
ENABLE_FLASH_SDP=0
ENABLE_MEM_EFFICIENT_SDP=0
ENABLE_MATH_SDP=1
ENABLE_FUSED_ADAM=0
ENABLE_TF32=0

TIED_EMBED_LR=0.01
MATRIX_LR=0.01
SCALAR_LR=0.01
ADAM_EPS=1e-4
GRAD_CLIP_NORM=1.0

ITERATIONS=50
TRAIN_BATCH_TOKENS=16384
VAL_BATCH_SIZE=16384
TRAIN_SEQ_LEN=1024
VAL_LOSS_EVERY=0
TRAIN_LOG_EVERY=10
MAX_WALLCLOCK_SECONDS=0
