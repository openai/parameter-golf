# Parameter Golf environment variables (curated starter).
#
# Every knob in train_gpt.py is an environment variable. This file lists the
# ~17 most commonly tuned ones. For the full ~40-var list, see the
# Hyperparameters class at train_gpt.py:39-87 (and train_gpt_mlx.py:43-97).
#
# Usage:
#   cp .env.example .env    # (.env is NOT gitignored — do not commit secrets)
#   export $(grep -v '^#' .env | xargs)   # load into shell
# or pass inline:
#   RUN_ID=foo ITERATIONS=200 torchrun --standalone --nproc_per_node=1 train_gpt.py

# --- Run identity & data paths ----------------------------------------------
RUN_ID=my_run
DATA_PATH=./data/datasets/fineweb10B_sp1024
TOKENIZER_PATH=./data/tokenizers/fineweb_1024_bpe.model
SEED=1337

# --- Training schedule (most common knobs) ----------------------------------
ITERATIONS=20000                  # total training steps; smoke runs use 200-500
WARMUP_STEPS=20                   # LR warmup steps at the start
WARMDOWN_ITERS=1200               # LR warmdown steps at the end
MAX_WALLCLOCK_SECONDS=600.0       # hard cap; set to 0 to disable (not allowed for leaderboard)
TRAIN_BATCH_TOKENS=524288         # tokens per step
TRAIN_SEQ_LEN=1024                # training sequence length

# --- Validation cadence -----------------------------------------------------
VAL_LOSS_EVERY=1000               # validate every N steps; 0 = only at end
VAL_BATCH_SIZE=524288             # tokens per validation batch

# --- Model shape ------------------------------------------------------------
VOCAB_SIZE=1024                   # must match the tokenizer at TOKENIZER_PATH
NUM_LAYERS=9
MODEL_DIM=512
NUM_HEADS=8
NUM_KV_HEADS=4                    # GQA KV heads (divides NUM_HEADS)
MLP_MULT=2                        # MLP expansion factor

# --- For the full list (optimizer LRs, Muon momentum, RoPE base, logit
# --- softcap, QK-gain, grad-clip, etc.), see the Hyperparameters class in
# --- train_gpt.py lines 39-87 (CUDA) and train_gpt_mlx.py lines 43-97 (MLX).

# --- DO NOT SET MANUALLY: these are injected by torchrun ---
# RANK
# WORLD_SIZE
# LOCAL_RANK
