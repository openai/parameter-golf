  "starter_ideas": [
    {
      "family_match_rank": 0,
      "horizon": "medium_term",
      "idea_id": "shared_depth_recurrence_3x_unroll",
      "implementation_sketch": "Start from the current trunk, keep attention/MLP shapes fixed, tie block weights across repeated steps, inject a learned step embedding, and add minimal per-step scaling to avoid optimization collapse.",
      "primary_family": "architecture",
      "priority": 1,
      "risk": "high",
      "secondary_families": [],
      "source_refs": [
        "https://arxiv.org/abs/1807.03819"
      ],
      "summary": "Replace many untied layers with 2-3 shared blocks unrolled multiple times, using step embeddings and per-step gates or norms.",
      "tags": [
        "parameter_sharing",
        "recurrent_depth",
        "challenge_native"
      ],
      "title": "3-block shared-depth recurrence",
      "why_it_fits": "The challenge is byte-constrained but not compute-starved, so reusing parameters across depth is a direct way to buy more effective depth per byte."
    },
    {
      "family_match_rank": 0,
      "horizon": "medium_term",
      "idea_id": "factorized_embeddings_sp4096",
      "implementation_sketch": "Introduce vocab->embed_dim and embed_dim->model_dim factors with tied decoding through the transpose path. Sweep embed_dim aggressively downward and pair it with a higher-vocab sentencepiece variant.",
      "primary_family": "architecture",
      "priority": 2,
      "risk": "medium",
      "secondary_families": [
        "tokenizer"
      ],
      "source_refs": [
        "https://arxiv.org/abs/1909.11942"
      ],
      "summary": "Factor the token embedding/output map so the model can afford a 2k-4k tokenizer without paying a full vocab x model_dim byte tax.",
      "tags": [
        "factorized_embeddings",
        "tokenizer",
        "byte_reallocation"
      ],
      "title": "Factorized tied embeddings with larger vocab",
      "why_it_fits": "The current baseline keeps vocab small because embeddings are expensive. Factorization can reallocate bytes from embeddings into a better tokenizer or a slightly stronger trunk."
    },
    {
      "family_match_rank": 1,
      "horizon": "near_term",
      "idea_id": "mtp_aux_heads_train_only",
      "implementation_sketch": "Reuse the final hidden states. Add two lightweight projection heads for t+2 and t+3 targets, weight their losses below the main next-token loss, and strip the extra heads before serialization and eval.",
      "primary_family": "training_recipe",
      "priority": 1,
      "risk": "medium",
      "secondary_families": [
        "architecture"
      ],
      "source_refs": [
        "https://arxiv.org/abs/2404.19737"
      ],
      "summary": "Add 2 auxiliary future-token heads on top of the shared trunk during training, then drop them before export so bytes stay nearly unchanged.",
      "tags": [
        "sample_efficiency",
        "train_only",
        "export_free"
      ],
      "title": "Train-only multi-token heads",
      "why_it_fits": "Parameter Golf is wallclock-limited, so sample-efficiency improvements that disappear at export are unusually attractive."
    },
    {
      "family_match_rank": 1,
      "horizon": "moonshot",
      "idea_id": "aqlm_style_codebook_mlp",
      "implementation_sketch": "Start with MLP matrices only. Replace full tensors with codebook indices plus a small shared codebook, optionally with a low-rank residual. First try post-training codebooks, then move to jointly learned codebooks if the export path stays stable.",
      "primary_family": "compression",
      "priority": 2,
      "risk": "high",
      "secondary_families": [
        "architecture"
      ],
      "source_refs": [
        "https://arxiv.org/abs/2401.06118"
      ],
      "summary": "Treat the largest MLP matrices as additive-codebook or prototype-compressed weights so artifact bytes fall faster than with naive int8 per-row quantization.",
      "tags": [
        "codebook_quantization",
        "extreme_compression",
        "mlp_heavy"
      ],
      "title": "AQLM-style codebook MLP compression",
      "why_it_fits": "Most of the baseline parameter mass sits in large matrices, especially MLPs. Extreme-compression methods target exactly that regime."
    }
