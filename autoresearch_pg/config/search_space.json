{
  "parameters": {
    "NUM_LAYERS": {
      "type": "int",
      "values": [6, 7, 8, 9, 10, 12],
      "note": "Baseline-compatible depth sweep."
    },
    "MODEL_DIM": {
      "type": "int",
      "values": [448, 512, 576, 640, 768],
      "note": "Small-model width sweep."
    },
    "NUM_HEADS": {
      "type": "int",
      "values": [7, 8, 9, 10, 12],
      "note": "Must divide MODEL_DIM."
    },
    "NUM_KV_HEADS": {
      "type": "int",
      "values": [2, 3, 4, 5, 6],
      "note": "Prefer divisors of NUM_HEADS."
    },
    "MLP_MULT": {
      "type": "int",
      "values": [1, 2, 3],
      "note": "MLP matrices dominate the parameter budget."
    },
    "TIED_EMBED_LR": {
      "type": "float",
      "values": [0.03, 0.05, 0.07, 0.1]
    },
    "MATRIX_LR": {
      "type": "float",
      "values": [0.03, 0.04, 0.05]
    },
    "SCALAR_LR": {
      "type": "float",
      "values": [0.02, 0.04, 0.06]
    },
    "WARMDOWN_ITERS": {
      "type": "int",
      "values": [256, 512, 800, 1200]
    },
    "WARMUP_STEPS": {
      "type": "int",
      "values": [20, 64, 128]
    },
    "QK_GAIN_INIT": {
      "type": "float",
      "values": [1.0, 1.25, 1.5, 1.75]
    },
    "LOGIT_SOFTCAP": {
      "type": "float",
      "values": [20.0, 30.0, 40.0]
    }
  },
  "experimental_features": {
    "shared_depth_recurrence": {
      "status": "planned",
      "note": "Likely a high-upside architecture family for this challenge."
    },
    "multi_token_prediction": {
      "status": "planned",
      "note": "Training-only auxiliary heads, removed before export."
    },
    "factorized_embeddings": {
      "status": "planned",
      "note": "Important once tokenizer search is automated."
    },
    "qat_export_alignment": {
      "status": "planned",
      "note": "Target the post-quant metric directly."
    }
  }
}
