# Controller host -> Runpod worker contract.
# Copy this file, fill in the real values, then deploy with:
# python3 infra/hetzner/deploy_controller.py --host user@hetzner --env-file /path/to/autoresearch.env --start

PROPOSER_MODEL=gpt-5.4
PRE_REVIEW_MODEL=gpt-5.4
POST_REVIEW_MODEL=gpt-5.4

# The GPU worker the controller will SSH into.
REMOTE_HOST=root@runpod-worker
REMOTE_PORT=22
REMOTE_REPO_DIR=/workspace/parameter-golf
REMOTE_BRANCH=runpod-autoresearch
PUSH_REMOTE=fork
REMOTE_FETCH_REMOTE=origin
REMOTE_TORCHRUN=/usr/local/bin/torchrun
REMOTE_IDENTITY=/home/your-user/.ssh/runpod_ed25519
# Optional boolean override. The controller auto-enables PTY mode for *.runpod.io.
REMOTE_SSH_FORCE_TTY=1

# Experiment defaults.
DATA_PATH=/workspace/parameter-golf/data/datasets/fineweb10B_sp1024
TOKENIZER_PATH=/workspace/parameter-golf/data/tokenizers/fineweb_1024_bpe.model
VOCAB_SIZE=1024
ITERATIONS=20000
MAX_WALLCLOCK_SECONDS=600
VAL_LOSS_EVERY=0
NPROC_PER_NODE=1
MAX_PRE_REVIEW_ROUNDS=3
PREP_QUEUE_DEPTH=1

# Baseline train_gpt.py overrides shared by each candidate run.
BASE_EXTRA_ENV=TRAIN_BATCH_TOKENS=524288 VAL_BATCH_SIZE=524288 TRAIN_SEQ_LEN=1024 EVAL_SEQ_LEN=1024

# Trace and ledger locations on the controller host.
TRACE_ROOT=controller_state/autoresearch
RESULTS_FILE=results.tsv
REVIEWS_FILE=reviews.tsv
HARNESS_LOG=logs/autoresearch_hetzner.log

# Optional monitor tuning for infra/hetzner/monitor_controller.py.
MONITOR_CODEX_MODEL=gpt-5.4
MONITOR_MAX_IDLE_MINUTES=25
MONITOR_REMOTE_SILENCE_MINUTES=20
MONITOR_RUN_GRACE_MINUTES=20
MONITOR_CODEX_COOLDOWN_MINUTES=60
MONITOR_AUTO_RESTART_SERVICE=1
MONITOR_JOURNAL_LINES=80
