{
  "name": "@trios/railway-mcp",
  "version": "0.0.1",
  "description": "MCP stdio server wrapping tri-railway CLI for Claude Desktop / MCP clients. Anchor: phi^2 + phi^-2 = 3.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "trios-railway-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "@types/node": "^22.7.4"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": ["mcp", "model-context-protocol", "railway", "trios", "trinity"]
}
