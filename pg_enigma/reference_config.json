{
  "cycle_id": "train_gpt_enigma",
  "history_window": 4,
  "workspace": {
    "root": "runs"
  },
  "prompts": {
    "explorer": "pg_enigma/explorer_prompt.md",
    "verifier": "pg_enigma/verifier_prompt.md",
    "distiller": "pg_enigma/distiller_prompt.md",
    "compiler": "pg_enigma/compiler_prompt.md",
    "analyst": "pg_enigma/analyst_prompt.md"
  },
  "schemas": {
    "explorer": "pg_enigma/exploration_slate_schema.json",
    "verifier": "pg_enigma/verification_report_schema.json",
    "distiller": "pg_enigma/campaign_schema.json",
    "compiler": "pg_enigma/family_compile_schema.json",
    "analyst": "pg_enigma/postmortem_schema.json"
  },
  "codex": {
    "bin": "codex",
    "model": "gpt-5.4",
    "reasoning_effort": "high",
    "models": {
      "explorer": "gpt-5.4",
      "verifier": "gpt-5.4",
      "distiller": "gpt-5.4",
      "compiler": "gpt-5.4",
      "analyst": "gpt-5.4"
    },
    "profile": null,
    "sandbox": "workspace-write",
    "cd": ".",
    "max_attempts": 2,
    "full_auto": true,
    "skip_git_repo_check": true,
    "extra_args": []
  },
  "objective": {
    "target_script": "train_gpt.py",
    "goal": "minimize credible val_bpb",
    "primary_metric": "final_int8_zlib_roundtrip_exact val_bpb",
    "secondary_metrics": [
      "in-run val_bpb",
      "control spread",
      "artifact size or latency only as tie-breakers"
    ],
    "notes": [
      "Project-level search may change tokenizer, vocab, base stack, quantization path, and architecture.",
      "Cycle-level search should freeze only the dimensions required for a fair comparison.",
      "Do not ask for more child mutations when the evidence says the search level itself is wrong."
    ]
  },
  "exploration": {
    "trajectories": 4,
    "families_per_trajectory": 4
  },
  "verification": {
    "min_keep": 2,
    "min_consequence_score": 4,
    "min_falsifiability_score": 3,
    "min_implementation_honesty_score": 3
  },
  "compiler": {
    "realizations_per_family": 3,
    "min_ready_realizations": 1
  },
  "packing": {
    "controls_per_pack": 2,
    "max_candidates_per_pack": 4,
    "max_realizations_per_family_per_pack": 2
  },
  "promotion": {
    "min_positive_realizations": 2,
    "min_surviving_realizations": 1,
    "require_directional_support": true
  },
  "composition": {
    "max_pairwise_candidates": 6,
    "max_hybrid_candidates": 4
  },
  "reference_docs": [
    "findings.md",
    "search_strategy_catalog.md",
    "search_strategy_meta_prompt.md",
    "search_verifier_codex.md",
    "pg_enigma/self_check_rubric.md"
  ],
  "handoff": {
    "default_search_harness_config": "ncycle/my_cycle.json",
    "default_repo_files": [
      "train_gpt.py"
    ]
  }
}
