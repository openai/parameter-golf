# Invocation (remote)
torchrun --standalone --nproc_per_node=8 train_gpt.py

# Stage 2: compiled checkpoint reload quant eval (winning under 32,000,000 bytes)
LOAD_MODEL_PATH=/root/code/openai-parameter-challenge/logs/sweeps/train_gpt_layouts_remote/speedrunb1_tgpt_kv11m4_no_tee_sched_03_d512_l11_h8_kv2_m4_v2048_144043.final_model.pt
