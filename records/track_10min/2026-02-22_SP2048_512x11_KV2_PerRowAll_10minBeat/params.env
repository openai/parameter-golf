# Recorded winning result (two-stage):
# 1) 10-minute training run on speedrunb1-0 (KV2 layout)
# 2) compiled reload quant-eval on saved checkpoint with tuned int8 settings

# Stage 1: exact-10-minute training layout (completed full 10k steps in 588414ms)
POD=speedrunb1-0
RUN_ID=speedrunb1_tgpt_kv11m4_no_tee_sched_03_d512_l11_h8_kv2_m4_v2048_144043
TOKENIZER_KIND=sp
TOKENIZER_PATH=data/matched_10B/tokenizers/fineweb_2048_bpe.model
