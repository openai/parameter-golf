{
  "_comment": "Partitioned MoE + PID + BigramHash + SmearGate + SlidingWindow + Int5/Int6",
  "_version": "10.0.0",

  "model": {
    "vocab_size": 1024,
    "num_layers": 9,
    "model_dim": 512,
    "num_heads": 8,
    "num_kv_heads": 4,
    "tie_embeddings": true,
    "tied_embed_init_std": 0.005,
    "logit_softcap": 30.0,
    "rope_base": 10000.0,
    "classical_layers": "0,1,2,6,7,8",
    "quant_bits": 6
  },

  "moe": {
    "num_experts": 4,
    "activation": "relu2",
    "routing": "hash_partition",
    "mlp_mult": 3
  },

  "partitions": {
    "0": {"layers": [0, 1, 2], "num_experts": 2, "mlp_mult": 2, "role": "input"},
    "1": {"layers": [3, 4, 5], "num_experts": 4, "mlp_mult": 3, "role": "middle"},
    "2": {"layers": [6, 7, 8], "num_experts": 4, "mlp_mult": 2, "role": "output"}
  },

  "hash": {
    "prime1": 36313,
    "prime2": 27191
  },

  "training": {
    "iterations": 20000,
    "train_batch_tokens": 786432,
    "train_seq_len": 2048,
    "max_wallclock_seconds": 600.0,
    "warmup_steps": 20,
    "warmdown_iters": 3000,
    "seed": 1337,
    "val_loss_every": 1000,
    "val_batch_size": 524288,
    "train_log_every": 200
  },

  "optimizer": {
    "embed_lr": 0.6,
    "head_lr": 0.008,
    "tied_embed_lr": 0.05,
    "matrix_lr": 0.04,
    "scalar_lr": 0.04,
    "muon_momentum": 0.99,
    "muon_backend_steps": 5,
    "muon_momentum_warmup_start": 0.92,
    "muon_momentum_warmup_steps": 1500,
    "beta1": 0.9,
    "beta2": 0.95,
    "adam_eps": 1e-8,
    "grad_clip_norm": 0.3,
    "weight_decay": 0.04
  },

  "eval": {
    "stride": 64,
    "batch_seqs": 32,
    "bigram_vocab_size": 10240,
    "bigram_dim": 128
  },

  "swa": {
    "enabled": true,
    "start_frac": 0.4,
    "every": 50
  },

  "ttt": {
    "lora_rank": 8,
    "lora_lr": 0.01,
    "chunk_size": 256,
    "eval_seq_len": 2048,
    "batch_size": 64
  }
}
