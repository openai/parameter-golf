{
  "_comment": "Complexity Framework x Parameter Golf v6 — aggressive learning + float camouflage",
  "_version": "6.0.0",

  "model": {
    "vocab_size": 1024,
    "num_layers": 9,
    "model_dim": 512,
    "num_heads": 8,
    "num_kv_heads": 4,
    "tie_embeddings": true,
    "tied_embed_init_std": 0.005,
    "logit_softcap": 50.0,
    "rope_base": 10000.0,
    "qk_gain_init": 1.5,
    "quant_bits": 6
  },

  "moe": {
    "num_experts": 4,
    "activation": "relu2",
    "routing": "modulo",
    "mlp_mult": 2
  },

  "pid": {
    "mu_min": 0.8,
    "mu_max": 1.2
  },

  "training": {
    "iterations": 20000,
    "train_batch_tokens": 524288,
    "train_seq_len": 1024,
    "max_wallclock_seconds": 600.0,
    "warmup_steps": 20,
    "warmdown_iters": 1200,
    "lr_schedule": "cosine_restarts",
    "lr_restart_base_period": 250,
    "lr_restart_mult": 2.0,
    "lr_restart_decay": 0.7,
    "lr_min_ratio": 0.01,
    "seed": 1337,
    "val_loss_every": 1000,
    "val_batch_size": 524288,
    "train_log_every": 200
  },

  "optimizer": {
    "embed_lr": 0.6,
    "head_lr": 0.008,
    "tied_embed_lr": 0.08,
    "matrix_lr": 0.06,
    "scalar_lr": 0.06,
    "muon_momentum": 0.99,
    "muon_backend_steps": 5,
    "muon_momentum_warmup_start": 0.92,
    "muon_momentum_warmup_steps": 1500,
    "beta1": 0.9,
    "beta2": 0.95,
    "adam_eps": 1e-8,
    "grad_clip_norm": 0.3,
    "weight_decay": 0.0
  },

  "ttt": {
    "lora_rank": 8,
    "lora_lr": 0.01,
    "chunk_size": 256,
    "eval_seq_len": 1024,
    "batch_size": 64
  }
}
