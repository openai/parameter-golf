"""
Enhanced train_gpt.py with 6 techniques from top-scoring parameter-golf submissions:
1. STE Fake Int6 QAT in CastedLinear
2. Int6 Post-Training Quantization (replaces int8)
3. FP16 Embedding Passthrough
4. Sliding Window Evaluation
5. Tuned Hyperparameter Defaults
6. NorMuon (per-row second moment normalization in Muon)

Hard stop: must never be longer than 1500 lines.
"""

from __future__ import annotations

