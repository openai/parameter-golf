    "model_file": "fineweb_1024_bpe.model"
  },

  "innovations_vs_baseline": [
    "XSA: local window attention + cross-chunk summary heads",
    "Value Residual: prev-layer V mixed into current layer",
    "ALiBi positional encoding enabling free context extension at eval",
    "Factorized embeddings (vocab->64->384) reducing embedding params",
    "Self-distillation: snapshot at 70%, soft KD for final 30%",
    "LoRA TTT: rank-4 adapters on Q+V, 5 AdamW steps per 256-token chunk",
    "N-gram mixer: PAQ-style bigram blended at 7% weight",
    "Temperature calibration (0.93) tuned for bpb not perplexity"
