  "architecture": {
    "type": "XSA-VR Transformer",
    "n_layers": 11,
    "d_model": 384,
    "n_heads": 6,
    "n_kv_heads": 2,
    "ffn_multiplier": 3,
    "ffn_activation": "SwiGLU",
