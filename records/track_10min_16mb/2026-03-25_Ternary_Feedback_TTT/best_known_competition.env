# ============================================================================
# BEST KNOWN COMPETITION OPERATING POINT — SKC SP8192
# Branch: skc_competition_sp8192  |  Last updated: 2026-04-10
# ============================================================================
# This file documents the best-known hyperparameter configuration.
# Source it before running or use it to override defaults:
#   source best_known_competition.env && bash run_skc_competition_8xh100.sh
#
# NOTE: Update this file (and the date above) whenever a sweep validates a
# better operating point. Include the proxy run BPB that motivated the change.
# ============================================================================

# Tokenizer (highest-leverage change vs research baseline)
DATA_PATH=/workspace/data/datasets/fineweb10B_sp8192
TOKENIZER_PATH=/workspace/data/tokenizers/fineweb_8192_bpe.model
VOCAB_SIZE=8192

# Architecture
ARCHITECTURE=skc_competition
NUM_LAYERS=8
MODEL_DIM=1536
NUM_HEADS=24
NUM_KV_HEADS=6
MLP_MULT=3
EMBED_DIM=256
SKC_PARALLEL_RESIDUAL=1
SKC_BLOCK_SIZE=64
SKC_NUM_CAPSULES=24
SKC_CAPSULE_DIM=64
SKC_CONV_KERNEL=4

# MoE (keep; re-qualified at SP8192)
MOE_ENABLED=1
MOE_NUM_EXPERTS=4
MOE_TOP_K=1
MOE_START_FRACTION=0.30
MOE_ROUTER_AUX_LOSS_COEF=0.01
MOE_LAYER_FRAC=0.67

# Virtual depth
TRAINING_DEPTH_RECURRENCE=0
RECURRENCE_DEPTH=2
RECURRENCE_START_FRACTION=0.35

# Frontier optimizer (higher WD + QK gain than research defaults)
MATRIX_LR=0.025
SCALAR_LR=0.018
TIED_EMBED_LR=0.030
HEAD_LR=0.018
MUON_WD=0.08
ADAM_WD=0.08
QK_GAIN_INIT=3.0
MUON_MOMENTUM=0.95
WARMDOWN_FRACTION=0.15
GRAD_CLIP_NORM=0.3

# EMA
EMA_ENABLED=1
EMA_DECAY=0.997
EMA_START_FRACTION=0.20

# TTT (legal score-first, skc_safe scope)
TTT_ENABLED=1
TTT_SCOPE=skc_safe
TTT_LR=0.003
TTT_EPOCHS=3
TTT_CHUNK_TOKENS=32768
TTT_MOMENTUM=0.9
TTT_BATCH_SEQS=32
TTT_GRAD_CLIP=1.0

# Competition export
EXPORT_MODE=competition_gptq
GPTQ_LITE_ENABLED=1
GPTQ_LITE_PERCENTILES=5
BITNET_GROUP_SIZE=128
TURBO_QUANT_TRAIN=1
TURBO_QUANT_EXPORT=1
LZMA_PRESET=3

