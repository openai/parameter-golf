# -----------------------------
# HYPERPARAMETERS
# -----------------------------
# Default run (after this submission's changes):
# - 9 transformer blocks at width 512
# - 8 attention heads with 4 KV heads (GQA) and 2.5x MLP expansion
# - vocab size 1024, sequence length 2048, tied embeddings
# - 786,432 train tokens per step (768 K) for 20,000 iterations with a ~10 minute cap

class Hyperparameters:
