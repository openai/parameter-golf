    def flash_attn_3_func(q, k, v, causal=True):
        # Fallback: convert from (B,T,H,D) to (B,H,T,D) for PyTorch SDPA
        q2 = q.transpose(1, 2)
        k2 = k.transpose(1, 2)
        v2 = v.transpose(1, 2)
        num_heads, num_kv = q2.size(1), k2.size(1)
        y = F.scaled_dot_product_attention(q2, k2, v2, attn_mask=None, is_causal=causal,
                                           enable_gqa=(num_kv != num_heads))
        return y.transpose(1, 2)
