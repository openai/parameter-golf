"""
OpenAI Parameter Golf - H-Net Byte-Level Language Model (Non-Record Submission)
First tiny H-Net: learned byte-level tokenization via dynamic chunking.
Architecture: byte encoder (causal conv) → learned chunking gate → transformer → EMA dechunk → decoder.

Reference: arXiv:2507.07955 (Hwang, Wang, Gu - Goomba Lab)
"""

from __future__ import annotations

import copy
import glob
import io
import math
import os
import random
import subprocess
import sys
import time
import uuid
import zlib
from pathlib import Path

import numpy as np
import torch
import torch.distributed as dist
import torch.nn.functional as F
from torch import Tensor, nn
from torch.nn.parallel import DistributedDataParallel as DDP

