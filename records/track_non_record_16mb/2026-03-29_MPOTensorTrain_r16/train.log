class MPOLinear(nn.Module):
    def __init__(self, in_features, out_features, rank=16):
        super().__init__()
        self.r = rank
        self.out_features = out_features
        
        self.i1 = 16
        self.i2 = in_features // 16
        self.o1 = 16
        self.o2 = out_features // 16
        
        # Initialize the low-rank Tensor Cores
        self.core1 = nn.Parameter(torch.randn(self.i1, self.o1, self.r) / (self.i1 * self.r)**0.5)
        self.core2 = nn.Parameter(torch.randn(self.r, self.i2, self.o2) / (self.i2 * self.r)**0.5)
        self.bias = nn.Parameter(torch.zeros(out_features))

    def forward(self, x):
        batch_size, seq_len, _ = x.shape
        x_reshaped = x.view(batch_size, seq_len, self.i1, self.i2)
        
        # Force cores to match input dtype dynamically
        c1 = self.core1.to(x.dtype)
        c2 = self.core2.to(x.dtype)
        
        # Contract the tensor network
        out = torch.einsum('bsij,ior,rjp->bsop', x_reshaped, c1, c2)
        out = out.reshape(batch_size, seq_len, self.out_features)
        
        # Force bias to match input dtype dynamically
        return out + self.bias.to(x.dtype)

class MLP(nn.Module):
    def __init__(self, dim, mlp_mult):
        super().__init__()
        hidden_dim = int(dim * mlp_mult)
        
        # INJECT THE QUANTUM-INSPIRED MPO:
        self.c_fc    = MPOLinear(dim, hidden_dim, rank=16)
        
        self.gelu    = nn.GELU()
        # Use CastedLinear to perfectly match the baseline's precision expectations
        self.c_proj  = CastedLinear(hidden_dim, dim, bias=False)
        self.c_proj.NANOGPT_SCALE_INIT = 1

    def forward(self, x):
        x = self.c_fc(x)
        x = self.gelu(x)
        x = self.c_proj(x)
        return x

