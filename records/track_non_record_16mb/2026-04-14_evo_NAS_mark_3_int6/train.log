# ==============================================================================
# SHARD FORMAT + COMPUTE DTYPE
# ==============================================================================

COMPUTE_DTYPE = mx.bfloat16

# Set in main() from env; CastedLinear reads for fake-QAT (straight-through).
_QAT_CTX: dict = {}


def set_qat_context(
    bits: int,
    scheme: str,
    slope: float,
    num_heads: int,
    head_dim: int,
) -> None:
    global _QAT_CTX
    _QAT_CTX = {
        "bits": int(bits),
        "scheme": scheme,
        "slope": float(slope),
        "num_heads": int(num_heads),
        "head_dim": int(head_dim),
    }


def apply_fake_quant_weight(w: mx.array, linear_kind: str) -> mx.array:
    """Symmetric STE fake-quant on weight; gradients flow through identity on w."""
    bits = int(_QAT_CTX.get("bits", 0))
    if bits <= 0:
        return w
    scheme = _QAT_CTX.get("scheme", "per_tensor")
    slope = float(_QAT_CTX.get("slope", 1.0))
    num_heads = int(_QAT_CTX.get("num_heads", 0))
    head_dim = int(_QAT_CTX.get("head_dim", 0))
    max_q = float(2 ** (bits - 1) - 1)
    wf = w.astype(mx.float32)
    eps = 1e-8

    if scheme == "per_tensor":
        scale = mx.maximum(mx.max(mx.abs(wf)) / max_q, eps)
        q = mx.clip(mx.round(wf / scale), -max_q, max_q)
        dq = q * scale
    elif scheme == "per_channel":
        scale = mx.maximum(mx.max(mx.abs(wf), axis=1, keepdims=True) / max_q, eps)
        q = mx.clip(mx.round(wf / scale), -max_q, max_q)
        dq = q * scale
    elif scheme == "per_head" and linear_kind == "attn" and num_heads > 0 and wf.shape[0] % num_heads == 0:
        out_d, in_d = wf.shape
        hd = out_d // num_heads
        w2 = wf.reshape(num_heads, hd, in_d)
        scale = mx.maximum(mx.max(mx.abs(w2), axis=(1, 2), keepdims=True) / max_q, eps)
        q = mx.clip(mx.round(w2 / scale), -max_q, max_q)
        dq = (q * scale).reshape(out_d, in_d)
    else:
        scale = mx.maximum(mx.max(mx.abs(wf), axis=1, keepdims=True) / max_q, eps)
        q = mx.clip(mx.round(wf / scale), -max_q, max_q)
        dq = q * scale

    ste = wf + mx.stop_gradient(slope * (dq.astype(mx.float32) - wf))
    return ste.astype(w.dtype)

# ==============================================================================
# M1 MAX / APPLE SILICON DEFAULTS
# ==============================================================================
# On arm64 (M1/M2/M3), use smaller batches to avoid OOM on 24–32GB unified memory.
def _m1_default(env_key: str, cuda_val: int, m1_val: int) -> int:
    v = os.environ.get(env_key)
    if v is not None:
        return int(v)
    return m1_val if platform.machine() == "arm64" else cuda_val


