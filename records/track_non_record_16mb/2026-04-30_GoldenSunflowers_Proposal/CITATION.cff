    repository-code: "https://github.com/gHashTag/trios-trainer-igla"
    authors:
      - alias: "gHashTag"
        name: "TRINITY S³AI"
    notes: "Anchor: phi^2 + phi^-2 = 3. Mirrors src/phi_ortho_init.rs into PyTorch."
