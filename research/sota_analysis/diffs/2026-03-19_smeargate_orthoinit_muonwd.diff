+def eval_val_sliding_window(args: Hyperparameters, base_model: nn.Module, rank: int, world_size: int, device: torch.device, val_tokens: Tensor, base_bytes_lut: Tensor, has_leading_space_lut: Tensor, is_boundary_token_lut: Tensor, stride: int=64) -> tuple[float, float]:
