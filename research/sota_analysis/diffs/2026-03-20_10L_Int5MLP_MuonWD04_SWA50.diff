+def eval_val_sliding(args: Hyperparameters, base_model: nn.Module, rank: int, world_size: int, device: torch.device, val_tokens: Tensor, base_bytes_lut: Tensor, has_leading_space_lut: Tensor, is_boundary_token_lut: Tensor, stride: int, batch_seqs: int=32) -> tuple[float, float]:
